# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=5000
NODE_ENV=development
USE_HTTPS=false

# ============================================================================
# SSL CONFIGURATION (if USE_HTTPS=true)
# ============================================================================
SSL_CERT_PATH=
SSL_KEY_PATH=
SSL_CERT_FILENAME=server.crt
SSL_KEY_FILENAME=server.key
SSL_BASE_PATH=./ssl

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/chatapp
WUZ_DATABASE_URL=postgresql://user:password@localhost:5432/wuzapi
DB_SCHEMA_SYNC_ON_START=true
# `push` = code-first schema sync, `migrate` = apply Prisma migrations
DB_SCHEMA_SYNC_MODE=migrate
DB_SCHEMA_FILE=prisma/schema.app.prisma

# ============================================================================
# WHATSAPP API CONFIGURATION
# ============================================================================
WUZAPI=https://your-wuzapi-instance.com
WUZAPI_Token=your-wuzapi-token-here
WUZAPI_TIMEOUT_MS=30000

# ============================================================================
# FILE UPLOAD LIMITS
# ============================================================================
MAX_FILE_SIZE_MB=50

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
SOCKET_RATE_LIMIT=60

# ============================================================================
# TIMEZONE CONFIGURATION
# ============================================================================
# UTC-only backend (keep this 0)
TIMEZONE_OFFSET_HOURS=0

# ============================================================================
# LOGGING
# ============================================================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# ============================================================================
# SECURITY
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ============================================================================
# DEBUG
# ============================================================================
DEBUG_API_PUBLIC=false
