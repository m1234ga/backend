# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=5000
NODE_ENV=development
USE_HTTPS=false

# ============================================================================
# SSL CONFIGURATION (if USE_HTTPS=true)
# ============================================================================
SSL_CERT_PATH=
SSL_KEY_PATH=
SSL_CERT_FILENAME=server.crt
SSL_KEY_FILENAME=server.key
SSL_BASE_PATH=./ssl

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://10.212.134.200:3000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/chatapp

# ============================================================================
# WHATSAPP API CONFIGURATION
# ============================================================================
WUZAPI=http://localhost:8080
WUZAPI_Token=H4Zbhw72PBKdTIgS
WUZAPI_TIMEOUT_MS=30000

# ============================================================================
# FILE UPLOAD LIMITS
# ============================================================================
MAX_FILE_SIZE_MB=50

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
SOCKET_RATE_LIMIT=60

# ============================================================================
# TIMEZONE CONFIGURATION
# ============================================================================
# Timezone offset in hours (e.g., 2 for Cairo, -5 for EST)
TIMEZONE_OFFSET_HOURS=0

# ============================================================================
# LOGGING
# ============================================================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# ============================================================================
# SECURITY
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ============================================================================
# DEBUG
# ============================================================================
DEBUG_API_PUBLIC=false
